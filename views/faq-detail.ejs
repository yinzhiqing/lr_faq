<div class="breadcrumb">
  <a href="/">首页</a> <span>/</span>
  <a href="/faqs">全部问题</a> <span>/</span>
  <%= faq.title %>
</div>

<div class="card">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 style="font-size:1.4em"><%= faq.title %></h1>
      <p style="color:#888;font-size:0.85em;margin-top:4px;">
        产品: <% if (faq.product_name) { %><a href="/faqs?product=<%= faq.product_id %>" class="badge badge-product"><%= faq.product_name %></a><% } else { %>未分类<% } %>
        &nbsp;|&nbsp; 分类: <a href="/faqs?category=<%= faq.category_id %>"><%= faq.category_name || '未分类' %></a>
        &nbsp;|&nbsp; 更新: <%= faq.updated_at %>
      </p>
    </div>
    <div class="btn-group">
      <button class="btn btn-outline btn-sm" onclick="copyShareLink(<%= faq.id %>, this)">复制链接</button>
      <a href="/faqs/<%= faq.id %>/edit" class="btn btn-primary btn-sm">编辑</a>
      <form action="/faqs/<%= faq.id %>/delete" method="post" class="inline-form" onsubmit="return confirm('确认删除此问题？')">
        <button class="btn btn-danger btn-sm">删除</button>
      </form>
    </div>
  </div>
</div>

<div class="two-col">
  <div>
    <div class="card">
      <h2 style="font-size:1.1em;margin-bottom:12px;color:#e94560">问题</h2>
      <p><%= faq.question %></p>
    </div>

    <div class="card">
      <h2 style="font-size:1.1em;margin-bottom:12px;color:#2d6a4f">解决方案</h2>
      <div class="answer-content">
        <%- faq.answer.replace(/<script/g, '&lt;script').replace(/<iframe/g, '&lt;iframe') %>
      </div>
    </div>
  </div>

  <div>
    <div class="card">
      <h2 style="font-size:1.1em;margin-bottom:8px;">标签</h2>
      <% if (faq.tags.length === 0) { %>
        <p style="color:#888;font-size:0.9em;">无标签</p>
      <% } else { %>
        <div>
          <% faq.tags.forEach(t => { %>
            <a href="/faqs?tag=<%= t.id %>" class="tag tag-primary"><%= t.name %></a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card">
      <h2 style="font-size:1.1em;margin-bottom:8px;">附件 (<%= faq.files.length %>)</h2>
      <% if (faq.files.length === 0) { %>
        <p style="color:#888;font-size:0.9em;">无附件</p>
      <% } else { %>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <% faq.files.forEach((f, idx) => {
            const isImage = /^image\//.test(f.mime_type);
            const isVideo = /^video\//.test(f.mime_type);
            const vidId = 'vid-' + f.id;
          %>
            <div class="file-item<%= isVideo ? ' file-item-clickable' : '' %>" <%- isVideo ? `onclick="toggleVideo('${vidId}', this)"` : '' %>>
              <% if (isImage) { %>
                <a href="/files/<%= f.id %>/view" target="_blank" style="flex-shrink:0;" onclick="event.stopPropagation()">
                  <img src="/files/<%= f.id %>/view" alt="<%= f.original_name %>" class="thumb-preview">
                </a>
              <% } else if (isVideo) { %>
                <span class="file-icon video-icon">&#9654;</span>
              <% } else { %>
                <span class="file-icon doc-icon">&#128196;</span>
              <% } %>
              <div style="flex:1;min-width:0;">
                <div class="file-name-text"><%= f.original_name %></div>
                <div style="font-size:0.75em;color:#888;"><%= (f.size / 1024).toFixed(1) %> KB &middot; <%= isVideo ? '视频 - 点击播放' : isImage ? '图片' : '文件' %></div>
              </div>
              <a href="/files/<%= f.id %>/download" class="btn btn-outline btn-sm" onclick="event.stopPropagation()">下载</a>
              <form action="/files/<%= f.id %>/delete" method="post" class="inline-form" onsubmit="event.stopPropagation(); return confirm('确认删除此文件？')">
                <button class="btn btn-danger btn-sm">删除</button>
              </form>
            </div>
            <% if (isVideo) { %>
              <div class="video-player-wrapper" id="<%= vidId %>" style="display:none;">
                <video controls preload="metadata" class="video-player" playsinline>
                  <source src="/uploads/<%= f.filename %>" type="<%= f.mime_type %>">
                </video>
              </div>
            <% } %>
          <% }) %>
        </div>
      <% } %>

      <h3 style="font-size:0.95em;margin-top:16px;margin-bottom:8px;">上传新附件</h3>
      <form action="/faqs/<%= faq.id %>/edit" method="post" enctype="multipart/form-data">
        <input type="hidden" name="title" value="<%= faq.title %>">
        <input type="hidden" name="question" value="<%= faq.question %>">
        <input type="hidden" name="answer" value="<%= faq.answer %>">
        <input type="hidden" name="product_id" value="<%= faq.product_id || '' %>">
        <input type="hidden" name="category_id" value="<%= faq.category_id || '' %>">
        <% faq.tags.forEach(t => { %><input type="hidden" name="tag_ids" value="<%= t.id %>"><% }) %>
        <input type="file" name="files" accept="image/*,video/*,.pdf,.doc,.docx,.txt,.zip">
        <button class="btn btn-primary btn-sm" style="margin-top:8px">上传</button>
      </form>
    </div>
  </div>
</div>
