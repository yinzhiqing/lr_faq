<%
const isEdit = !!faq;
const pageTitle = isEdit ? '编辑问题' : '添加问题';
%>

<h1><%= pageTitle %></h1>

<div class="suggestions" id="suggestions-box" style="display:none"></div>

<form action="<%= isEdit ? `/faqs/${faq.id}/edit` : '/faqs' %>" method="post" enctype="multipart/form-data">
  <div class="card">
    <div class="form-row">
      <div class="form-group">
        <label>所属产品</label>
        <select name="product_id">
          <option value="">-- 选择产品 --</option>
          <% products.forEach(p => { %>
            <option value="<%= p.id %>" <%= (faq && faq.product_id == p.id) ? 'selected' : '' %>><%= p.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>分类</label>
        <select name="category_id">
          <option value="">-- 不分类 --</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>" <%= (faq && faq.category_id == c.id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>标题 *</label>
      <input type="text" name="title" id="title" value="<%= faq ? faq.title : '' %>" required>
    </div>
    <div class="form-group">
      <label>问题描述 *</label>
      <textarea name="question" id="question" required><%= faq ? faq.question : '' %></textarea>
    </div>
    <div class="form-group">
      <label>答案（支持 Markdown）</label>
      <textarea name="answer" id="answer" style="min-height:250px"><%= faq ? faq.answer : '' %></textarea>
    </div>
  </div>

  <div class="card">
    <div class="form-row">
      <div class="form-group">
        <label>标签</label>
        <div style="display:flex;flex-wrap:wrap;gap:6px;padding-top:6px;">
          <% allTags.forEach(t => { %>
            <label style="font-weight:normal;cursor:pointer;display:flex;align-items:center;gap:4px;font-size:0.9em;">
              <input type="checkbox" name="tag_ids" value="<%= t.id %>"
                <%= (faq && faq.tags && faq.tags.some(ft => ft.id === t.id)) ? 'checked' : '' %>>
              <%= t.name %>
            </label>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="form-group">
      <label>附件（图片/视频/文件）</label>
      <input type="file" name="files" multiple accept="image/*,video/*,.pdf,.doc,.docx,.txt,.zip">
    </div>
    <% if (faq && faq.files && faq.files.length > 0) { %>
      <div style="margin-top:8px;">
        <p style="font-size:0.85em;color:#888">已有附件:</p>
        <div class="file-list">
          <% faq.files.forEach(f => { %>
            <div class="file-item">
              <span class="file-name"><%= f.original_name %></span>
              <span class="file-size"><%= (f.size / 1024).toFixed(1) %> KB</span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="btn-group" style="margin-bottom:20px;">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="<%= isEdit ? `/faqs/${faq.id}` : '/faqs' %>" class="btn btn-outline">取消</a>
  </div>
</form>

<script>
const titleEl = document.getElementById('title');
const questionEl = document.getElementById('question');
const box = document.getElementById('suggestions-box');

async function fetchSuggestions() {
  const title = titleEl?.value || '';
  const question = questionEl?.value || '';
  if (!title && !question) { box.style.display = 'none'; return; }
  try {
    const resp = await fetch(`/faqs/api/classify/suggest?title=${encodeURIComponent(title)}&question=${encodeURIComponent(question)}`);
    const data = await resp.json();
    if (data.categories.length > 0 || data.tags.length > 0) {
      box.style.display = 'block';
      let html = '<strong>自动分类建议：</strong> ';
      if (data.categories.length > 0) html += '分类 → ' + data.categories.map(c => `<em>${c}</em>`).join(', ') + ' ';
      if (data.tags.length > 0) html += '标签 → ' + data.tags.map(t => `<em>${t}</em>`).join(', ');
      box.innerHTML = html;
    } else {
      box.style.display = 'none';
    }
  } catch(e) { box.style.display = 'none'; }
}

let debounceTimer;
titleEl?.addEventListener('input', () => { clearTimeout(debounceTimer); debounceTimer = setTimeout(fetchSuggestions, 500); });
questionEl?.addEventListener('input', () => { clearTimeout(debounceTimer); debounceTimer = setTimeout(fetchSuggestions, 500); });
</script>
