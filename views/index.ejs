<% var gmx = locals.guestModules || { home: true, faqs: true, files: true }; %>
<section class="hero-apple" aria-labelledby="hero-title">
  <div class="hero-apple__inner">
    <p class="hero-eyebrow">内部知识库</p>
    <h1 id="hero-title" class="display-hero-apple">产品知识库</h1>
    <p class="hero-subtitle-apple">面向团队的问题、文档与附件检索。快速找到答案与解决方案。</p>
    <% if (locals.currentUser || gmx.faqs) { %>
    <form action="/faqs" method="get" class="hero-search-apple">
      <input type="text" name="q" placeholder="搜索问题、报错或配置方法…" aria-label="搜索问题">
      <button class="btn btn-primary" type="submit">搜索</button>
    </form>
    <% } else { %>
    <p class="hero-subtitle-apple" style="margin-top:12px">登录后可搜索知识库。</p>
    <% } %>
    <div class="hero-stats-apple">
      <span><strong><%= totalProducts %></strong> 个产品</span>
      <span><strong><%= totalFaqs %></strong> 条知识</span>
    </div>
  </div>
</section>

<div class="section-block">
  <p class="section-eyebrow">浏览</p>
  <div class="page-header page-header--apple">
    <h2 class="section-title-apple">按产品浏览</h2>
    <% if (locals.currentUser && currentUser.role === 'admin') { %>
      <a href="/products" class="btn btn-ghost btn-sm">管理产品</a>
    <% } %>
  </div>
</div>
<div class="product-grid">
  <% products.forEach(p => { %>
    <% if (locals.currentUser || gmx.faqs) { %>
    <a href="/faqs?product=<%= p.id %>" class="product-card">
    <% } else { %>
    <div class="product-card product-card--muted">
    <% } %>
      <div class="product-icon" aria-hidden="true"><%= p.name && p.name.length ? p.name.charAt(0) : '·' %></div>
      <div class="product-info">
        <div class="product-name"><%= p.name %></div>
        <div class="product-desc"><%= p.description || '' %></div>
        <div class="product-count"><%= p.faq_count %> 条知识</div>
      </div>
    <% if (locals.currentUser || gmx.faqs) { %>
    </a>
    <% } else { %>
    </div>
    <% } %>
  <% }) %>
  <% if (products.length === 0) { %>
    <div class="card card--muted grid-span-all">暂无产品<% if (locals.currentUser && currentUser.role === 'admin') { %>，请先 <a href="/products">添加产品</a><% } %>。</div>
  <% } %>
</div>

<div class="section-block section-block--spaced">
  <p class="section-eyebrow">最新</p>
  <div class="page-header page-header--apple">
    <h2 class="section-title-apple">最新更新</h2>
    <% if (locals.currentUser || gmx.faqs) { %>
    <a href="/faqs" class="btn btn-ghost btn-sm">查看全部</a>
    <% } %>
  </div>
</div>
<% if (locals.currentUser || gmx.faqs) { %>
<div class="recent-list">
  <% recentFaqs.forEach(faq => { %>
    <div class="recent-item">
      <div class="recent-main">
        <a href="/faqs/<%= faq.id %>" class="recent-title"><%= faq.title %></a>
        <div class="recent-meta">
          <span class="badge badge-product"><%= faq.product_name || '未分类' %></span>
          <% if (faq.category_name) { %><span class="badge"><%= faq.category_name %></span><% } %>
        </div>
      </div>
      <div class="recent-actions">
        <span class="recent-time"><%= faq.updated_at %></span>
        <button class="btn btn-ghost btn-sm" onclick="copyShareLink(<%= faq.id %>, this)">复制链接</button>
      </div>
    </div>
  <% }) %>
  <% if (recentFaqs.length === 0) { %>
    <div class="card card--muted">暂无内容</div>
  <% } %>
</div>
<% } else { %>
<p class="caption text-center" style="margin-bottom: var(--space-4)">登录后可查看知识条目与附件。</p>
<% } %>

<% if (locals.currentUser && currentUser.role === 'admin') { %>
<div class="text-center mt-footer-cta">
  <a href="/faqs/new" class="btn btn-primary">添加新问题</a>
</div>
<% } %>
