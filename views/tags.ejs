<div class="page-header">
  <h1>标签管理</h1>
</div>

<div class="two-col">
  <div class="card">
    <h2 style="font-size:1.1em;margin-bottom:12px">
      <%= current ? '编辑标签' : '新建标签' %>
    </h2>
    <form action="<%= current ? `/tags/${current.id}/edit` : '/tags' %>" method="post">
      <div class="form-group">
        <label>名称 *</label>
        <input type="text" name="name" value="<%= current ? current.name : '' %>" required>
      </div>
      <div class="btn-group">
        <button type="submit" class="btn btn-primary"><%= current ? '保存' : '创建' %></button>
        <% if (current) { %><a href="/tags" class="btn btn-outline btn-sm">取消</a><% } %>
      </div>
    </form>
  </div>

  <div class="card">
    <h2 style="font-size:1.1em;margin-bottom:12px">标签列表</h2>
    <% if (tags.length === 0) { %>
      <p style="color:#888">暂无标签。</p>
    <% } else { %>
      <table>
        <thead><tr><th>名称</th><th>关联 FAQ 数</th><th>操作</th></tr></thead>
        <% tags.forEach(t => { %>
          <tr>
            <td><span class="tag"><%= t.name %></span></td>
            <td><%= t.faq_count %></td>
            <td>
              <div class="btn-group">
                <a href="/tags/<%= t.id %>/edit" class="btn btn-outline btn-sm">编辑</a>
                <form action="/tags/<%= t.id %>/delete" method="post" class="inline-form" onsubmit="return confirm('确认删除此标签？')">
                  <button class="btn btn-danger btn-sm">删除</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </table>
    <% } %>
  </div>
</div>
